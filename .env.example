APP__NAME=Social Persona AI
APP__ENV=dev
APP__DEBUG=true
APP__TIMEZONE=Asia/Shanghai

STORAGE__SQLITE_DB_PATH=social_persona_ai.db
STORAGE__POSTGRES_DSN=postgresql://localhost:5432/social_persona_ai
STORAGE__VECTOR_DSN=http://localhost:6333
STORAGE__VECTOR_COLLECTION=persona_memory

EMOTION__DECAY=0.05
EMOTION__GAIN=0.8
EMOTION__MAX_HISTORY=1000

RETRIEVAL__TOP_K=5
RETRIEVAL__MIN_SCORE=0.2
RETRIEVAL__RECENCY_WINDOW_DAYS=30

PERSONA__NAME=LinXi
PERSONA__POLICY_NOTICE_ON_FIRST_TURN=true
PERSONA__ASSETS_DIR=prompt_assets

LLM__PROVIDER=kilo
LLM__MODEL=kilo-free
LLM__API_KEY=
LLM__BASE_URL=https://gateway.kilo.ai/v1
LLM__TEMPERATURE=0.7
LLM__TIMEOUT_SECONDS=30

ONEBOT__ENABLED=true
ONEBOT__WS_URL=http://xxx.xxx.xxx.xxx:xxxx
ONEBOT__TOKEN=xxxx
ONEBOT__MESSAGE_FORMAT=array
ONEBOT__RECONNECT_INTERVAL_SECONDS=3
ONEBOT__DEBUG_ONLY_USER_ID=xxxx
