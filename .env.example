# 应用名称（用于日志与服务标题）
APP__NAME=Social Persona AI
# 运行环境标识（如 dev/test/prod）
APP__ENV=dev
# 是否开启调试模式
APP__DEBUG=true
# 应用时区（影响时间上下文与日志展示）
APP__TIMEZONE=Asia/Shanghai

# SQLite 数据库文件路径
STORAGE__SQLITE_DB_PATH=social_persona_ai.db
# Postgres 连接串（当前可选，默认未启用）
STORAGE__POSTGRES_DSN=postgresql://localhost:5432/social_persona_ai
# 向量库连接地址（当前可选，默认未启用）
STORAGE__VECTOR_DSN=http://localhost:6333
# 向量集合名称
STORAGE__VECTOR_COLLECTION=persona_memory

# 情绪衰减系数（0-1）
EMOTION__DECAY=0.05
# 情绪增益系数（0-2）
EMOTION__GAIN=0.8
# 情绪历史最大长度
EMOTION__MAX_HISTORY=1000

# 记忆检索每轮返回条数
RETRIEVAL__TOP_K=5
# AI 自主检索最大轮次
RETRIEVAL__MAX_ROUNDS=3
# 检索最小分数阈值
RETRIEVAL__MIN_SCORE=0.2
# 记忆热度加权系数
RETRIEVAL__HEAT_BOOST_WEIGHT=0.15
# 热度按天衰减比例
RETRIEVAL__HEAT_DECAY_PER_DAY=0.08
# 命中后热度增量
RETRIEVAL__HEAT_INCREMENT_ON_ACCESS=0.12
# 记忆召回时间窗口（天）
RETRIEVAL__RECENCY_WINDOW_DAYS=30
# 跨对话正向关系阈值
RETRIEVAL__CROSS_POSITIVE_THRESHOLD=0.2
# 跨对话中性关系阈值
RETRIEVAL__CROSS_NEUTRAL_THRESHOLD=0.35
# 跨对话负向关系阈值
RETRIEVAL__CROSS_NEGATIVE_THRESHOLD=0.6
# 跨对话访问最小关系强度
RETRIEVAL__RELATION_ACCESS_MIN_STRENGTH=0.2

# 人设名称
PERSONA__NAME=杏桃
# 首轮是否注入策略提示
PERSONA__POLICY_NOTICE_ON_FIRST_TURN=true
# 人设与提示词资产目录
PERSONA__ASSETS_DIR=prompt_assets

# 会话续期阈值（小时，超过无交互则换新 session_id）
SESSION__RENEW_AFTER_HOURS=3.0

# 画像生成读取的近期消息条数
PROFILE__RECENT_MESSAGE_LIMIT=30

# 近期对话参考：从当前会话 scope 已落库消息中向前取 N 条（早于本轮窗口），注入 system 作为低权重时空背景；0 表示关闭
CONVERSATION_HISTORY__REFERENCE_MESSAGE_LIMIT=0
# 参杂：在启用历史参考的前提下，混入其它会话消息（条数上限见下）；时间不早于本会话本批参考中最旧一条
CONVERSATION_HISTORY__CROSS_MIX_ENABLED=false
CONVERSATION_HISTORY__CROSS_MIX_MESSAGE_LIMIT=10
# 群聊下：是否混入同群内其它成员（不同 user_id）的消息；私聊下不生效
CONVERSATION_HISTORY__CROSS_MIX_OTHER_USERS_ENABLED=false
# 为 false 时参杂池排除群聊消息（仅私聊等非 group 记录）
CONVERSATION_HISTORY__CROSS_MIX_GROUP_CHAT_MESSAGES_ENABLED=true

# 后台任务队列是否启用
JOBS__ENABLED=false
# 后台任务 worker 数量
JOBS__WORKER_COUNT=1
# 后台任务队列容量
JOBS__QUEUE_SIZE=1000
# 后台任务最大重试次数
JOBS__MAX_RETRIES=2
# 死信队列保留上限
JOBS__DEAD_LETTER_LIMIT=200
# 周期维护任务是否启用
JOBS__MAINTENANCE_ENABLED=false
# 周期维护任务间隔（秒）
JOBS__MAINTENANCE_INTERVAL_SECONDS=60.0
# 情绪聚合窗口（分钟）
JOBS__EMOTION_WINDOW_MINUTES=30

# LLM 提供商（当前实现主要支持 kilo）
LLM__PROVIDER=kilo
# LLM 模型名称
LLM__MODEL=kilo-auto/free
# LLM API Key（留空则走降级策略）
LLM__API_KEY=
# LLM Base URL
LLM__BASE_URL=https://api.kilo.ai/api/gateway
# 生成温度
LLM__TEMPERATURE=0.7
# LLM 请求超时（秒）
LLM__TIMEOUT_SECONDS=30.0
# 启动时是否执行健康检查
LLM__STARTUP_HEALTHCHECK_ENABLED=false
# 失败重试最大次数
LLM__RETRY_MAX_ATTEMPTS=3
# 重试退避基线秒数
LLM__RETRY_BACKOFF_SECONDS=1.0
# 熔断触发失败次数
LLM__CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# 熔断开启时长（秒）
LLM__CIRCUIT_BREAKER_OPEN_SECONDS=30.0

# 对话节奏状态机总开关
RHYTHM__ENABLED=true
# 用户沉默触发锁定阈值（秒）
RHYTHM__SILENCE_SECONDS=15.0
# 是否启用单轮最大思考时限（关闭后不再出现“思考超时”占位回复；总时长仍受 WAIT_TIMEOUT 约束）
RHYTHM__ENABLE_MAX_THINK_SECONDS=true
# 单轮最大思考时限（秒）
RHYTHM__MAX_THINK_SECONDS=45.0
# 回复后冷却时间（秒）
RHYTHM__COOLDOWN_SECONDS=2.0
# 单条消息长文本阈值（字符）
RHYTHM__SINGLE_MESSAGE_CHAR_THRESHOLD=200
# 单条消息长文本阈值（估算 token）
RHYTHM__SINGLE_MESSAGE_TOKEN_THRESHOLD=400
# 窗口总长阈值（字符）
RHYTHM__WINDOW_CHAR_THRESHOLD=600
# 窗口总长阈值（估算 token）
RHYTHM__WINDOW_TOKEN_THRESHOLD=1200
# 是否启用终止词中断策略（关闭后忽略 TERMINATE_KEYWORDS）
RHYTHM__ENABLE_TERMINATE_KEYWORDS=true
# 终止意图关键词（JSON 数组字符串）
RHYTHM__TERMINATE_KEYWORDS=["算了","不用了","当我没说"]
# 等待窗口批次完成超时（秒）
RHYTHM__WAIT_TIMEOUT_SECONDS=90.0
# 窗口取消请求后，批处理线程等待取消状态保留时间（秒）
RHYTHM__BATCH_CANCEL_GRACE_SECONDS=12.0

# OneBot 开关
ONEBOT__ENABLED=false
# OneBot WebSocket 地址（支持 http/https 自动转 ws/wss）
ONEBOT__WS_URL=http://xxx.xxx.xxx.xxx:xxxx
# OneBot 鉴权 token
ONEBOT__TOKEN=xxxx
# OneBot 消息格式
ONEBOT__MESSAGE_FORMAT=array
# OneBot 重连间隔（秒）
ONEBOT__RECONNECT_INTERVAL_SECONDS=3.0
# 调试模式下允许的唯一用户 ID
ONEBOT__DEBUG_ONLY_USER_ID=1377820366
# 是否强制仅处理白名单群（true 时忽略所有非白名单群消息）
ONEBOT__FORCE_GROUP_WHITELIST=false
# 群白名单（JSON 数组）
ONEBOT__GROUP_AUTONOMOUS_WHITELIST=[]

# OCR 能力开关（RapidOCR）
OCR__ENABLED=false
# OCR 引擎（当前支持 rapidocr）
OCR__ENGINE=rapidocr
# OCR 图片最大大小（MB）
OCR__MAX_IMAGE_MB=10.0
# OCR 下载/读取超时（秒）
OCR__DOWNLOAD_TIMEOUT_SECONDS=15.0

# 视觉模型能力开关（OpenAI兼容接口）
VISION__ENABLED=false
# 视觉模型 Base URL（OpenAI compatible）
VISION__BASE_URL=
# 视觉模型名称
VISION__MODEL=
# 视觉模型 API Key
VISION__API_KEY=
# 视觉模型图片最大大小（MB）
VISION__MAX_IMAGE_MB=10.0
# 视觉模型下载/读取超时（秒）
VISION__DOWNLOAD_TIMEOUT_SECONDS=15.0

# 图像理解统一编排开关
IMAGE_UNDERSTANDING__ENABLED=false
# 同时启用 OCR 与 Vision 时，是否优先 OCR
IMAGE_UNDERSTANDING__PREFER_OCR_FIRST=true
# 结果融合策略（默认：ocr_plus_vision）
IMAGE_UNDERSTANDING__MERGE_STRATEGY=ocr_plus_vision

# 工具运行时总开关（false 时不进入工具循环）
TOOLS__ENABLED=true
# 工具循环最大轮次
TOOLS__MAX_ROUNDS=4
# 每轮最多工具调用次数
TOOLS__MAX_TOOL_CALLS_PER_ROUND=3
# 是否强制发送白名单（true 时 send_message 仅允许白名单目标）
TOOLS__FORCE_SEND_WHITELIST=false
# 发送目标白名单（JSON 数组，元素格式 channel:target_type:target_id）
TOOLS__ALLOWED_SEND_TARGETS=[]
# 每分钟发送调用上限
TOOLS__SEND_RATE_LIMIT_PER_MINUTE=10
# 非只读工具权限策略（allow|ask|deny）
TOOLS__NON_READONLY_PERMISSION_BEHAVIOR=allow
# 工具调用重试最大次数
TOOLS__RETRY_MAX_ATTEMPTS=2
# 工具调用重试退避序列（JSON 数组，单位秒）
TOOLS__RETRY_BACKOFF_SECONDS=[0.2,0.8,1.6]
# 可重试错误码列表（JSON 数组）
TOOLS__RETRYABLE_ERROR_CODES=["timeout","execution_failed"]
# 单工具结果预算上限（字符）
TOOLS__RESULT_BUDGET_PER_TOOL_CHARS=4000
# 单轮工具结果聚合预算上限（字符）
TOOLS__RESULT_BUDGET_TOTAL_CHARS=12000
# 注入统一决策提示中的工具执行摘要最大字符数
TOOLS__UNIFIED_DIGEST_MAX_CHARS=8000

# 用户↔杏桃关系策略（多标签 + 边界阈值）
RELATION__ENABLED=true
# 允许的 relation_tags 白名单（逗号分隔或 JSON 数组可通过环境覆盖；默认见代码）
RELATION__DEVELOPER_USER_IDS=["1377820366"]
# 命中开发者 QQ/用户 id 时自动加入 developer 标签并提升 role_priority
RELATION__PROMOTE_DEVELOPER_ROLE_PRIORITY=true
RELATION__BOUNDARY_WARN_TRUST_BELOW=0.35
RELATION__BOUNDARY_RESTRICTED_TRUST_BELOW=0.15
RELATION__RESTRICTED_ON_NEGATIVE_POLARITY=true
RELATION__HIGH_INTIMACY_TONE_HINT_ABOVE=0.72
# 群聊未 @ 且关系已 restricted 且信任极低时是否强制不回复（默认 false）
RELATION__GROUP_SKIP_WHEN_RESTRICTED_WITHOUT_MENTION=false
RELATION__GROUP_RESTRICTED_SKIP_TRUST_BELOW=0.12

# 延时任务调度开关
DELAYED_TASK__ENABLED=true
# 延时任务轮询间隔（秒）
DELAYED_TASK__POLL_INTERVAL_SECONDS=1.0
# 每次轮询最多 claim 的任务数
DELAYED_TASK__CLAIM_BATCH_SIZE=10
# 运行中任务判定为陈旧并回收的租约时长（秒）
DELAYED_TASK__STALE_LEASE_SECONDS=120.0
# 延时任务默认最大重试次数
DELAYED_TASK__MAX_ATTEMPTS=3
# 失败重试退避序列（JSON 数组，单位秒）
DELAYED_TASK__RETRY_BACKOFF_SECONDS=[10.0,30.0,60.0]
